# ============================================================================
# DESIGNHUB BACKEND - ENVIRONMENT VARIABLES
# ============================================================================
# SETUP: Copy to .env and fill in your actual values

# ============================================================================
# REQUIRED: Server Configuration
# ============================================================================
NODE_ENV=development
PORT=5000

# ============================================================================
# REQUIRED: MongoDB Connection
# ============================================================================
# Local: mongodb://127.0.0.1:27017/designhub (need MongoDB running)
# Atlas: mongodb+srv://username:password@cluster-abc.mongodb.net/designhub
MONGO_URI=mongodb://127.0.0.1:27017/designhub

# ============================================================================
# REQUIRED: JWT Authentication
# ============================================================================
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_replace_this_with_generated_value_min_32_chars
JWT_EXPIRE=7d

# ============================================================================
# OPTIONAL: Cloudinary Image Upload
# ============================================================================
# Sign up: https://cloudinary.com (free tier available)
# Leave empty to test without real uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================================================
# REQUIRED: Frontend URL (for CORS)
# ============================================================================
# Dev: http://localhost:5176
# Prod: https://your-domain.com
CLIENT_URL=http://localhost:5176

# ============================================================================
# CORS Configuration (Cross-Origin Resource Sharing)
# ============================================================================
# Comma-separated list of allowed origins
# Only these domains can make requests to this API
# Dev: Allow localhost variations for local testing
# Prod: Set to your frontend domain(s)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:4173
CORS_CREDENTIALS=true

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
# Global rate limit (applies to all routes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Authentication rate limit (login, register - strict to prevent brute force)
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# Upload rate limit (prevent resource exhaustion)
UPLOAD_RATE_LIMIT_WINDOW_MS=3600000
UPLOAD_RATE_LIMIT_MAX_REQUESTS=20

# Comment/post rate limit (prevent spam)
COMMENT_RATE_LIMIT_WINDOW_MS=3600000
COMMENT_RATE_LIMIT_MAX_REQUESTS=30

# ============================================================================
# OPTIONAL: Logging Configuration
# ============================================================================
LOG_LEVEL=development

# Show stack traces in error responses (SECURITY: disable in production)
SHOW_ERROR_STACK=false
